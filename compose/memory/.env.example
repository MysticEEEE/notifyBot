## Timezone
TZ=Asia/Shanghai

## Data paths
MOS_CUBE_PATH=/app/data
MEMOS_BASE_PATH=/app/data
FILE_LOCAL_PATH=/app/data
MOS_ENABLE_DEFAULT_CUBE_CONFIG=true
MOS_ENABLE_REORGANIZE=false
MOS_TEXT_MEM_TYPE=general_text
ASYNC_MODE=sync

## Chat LLM — use openai backend pointed at Ollama's OpenAI-compatible API
MOS_CHAT_MODEL_PROVIDER=openai
MOS_CHAT_MODEL=qwen3.5-instruct:9b
MOS_CHAT_TEMPERATURE=0.7
MOS_MAX_TOKENS=4096
MOS_TOP_P=0.9
MOS_TOP_K=50

## MemReader LLM (reuse Ollama)
MEMRADER_MODEL=qwen3.5-instruct:9b
MEMRADER_API_KEY=ollama
MEMRADER_API_BASE=http://ollama:11434/v1
MEMRADER_MAX_TOKENS=5000

## OpenAI key + base — point to Ollama's OpenAI-compatible endpoint
OPENAI_API_KEY=ollama
OPENAI_API_BASE=http://ollama:11434/v1

## Embedding (Ollama backend)
MOS_EMBEDDER_BACKEND=ollama
MOS_EMBEDDER_MODEL=bge-m3
OLLAMA_API_BASE=http://ollama:11434
EMBEDDING_DIMENSION=1024

## Reranker
MOS_RERANKER_BACKEND=cosine_local

## Graph store (Neo4j)
NEO4J_BACKEND=neo4j-community
NEO4J_URI=bolt://memos-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-neo4j-password>
NEO4J_DB_NAME=neo4j
MOS_NEO4J_SHARED_DB=false

## Vector store (Qdrant)
QDRANT_HOST=memos-qdrant
QDRANT_PORT=6333
QDRANT_URL=
QDRANT_API_KEY=

## Scheduler — disabled
MOS_ENABLE_SCHEDULER=false
API_SCHEDULER_ON=false
MEMSCHEDULER_USE_REDIS_QUEUE=false

## Internet search — disabled
ENABLE_INTERNET=false

## Preference memory — disabled
ENABLE_PREFERENCE_MEMORY=false

## Nacos — disabled
NACOS_ENABLE_WATCH=false

## Reader chunking
MEM_READER_BACKEND=simple_struct
MEM_READER_CHAT_CHUNK_TYPE=default
MEM_READER_CHAT_CHUNK_TOKEN_SIZE=1600
MEM_READER_CHAT_CHUNK_SESS_SIZE=10
MEM_READER_CHAT_CHUNK_OVERLAP=2
